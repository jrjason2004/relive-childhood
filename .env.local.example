# Gemini API key (used for research grounding + Nano Banana 2 image generation)
GEMINI_API_KEY=

# Real reference photos for grounding stills (lib/refimages.ts).
# Provider chain, first working provider wins:
#   1. DuckDuckGo images — keyless, unofficial, always on. Needs no config.
#   2. Bing Images HTML scrape — keyless fallback when DuckDuckGo is blocked.
#   3. Google Programmable Search — official fallback, free 100 queries/day.
#      Create at https://programmablesearchengine.google.com (enable
#      "Search the entire web" + image search), key from Google Cloud console.
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_CX=
#   4. SerpAPI — legacy paid Google Images scrape, only used if set.
# SERPAPI_KEY=

# Optional model overrides
GEMINI_RESEARCH_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image

# The film: 7 scenes × 2s (3 era-only warm slides + 4 researched moments).
# Each scene shows its Nano Banana still (Ken Burns) and upgrades in place to
# a Wan 2.2 motion clip. The shareable mp4 uses the first ~14s of the music.
# Set to 1 to switch to the legacy pure-clip path.
# NEXT_PUBLIC_USE_WAN=1

# Video: self-hosted Wan 2.2 I2V A14B (MoE) + 4-step Lightning, kept warm on
# 3× g6e.2xlarge (NVIDIA L40S) ComfyUI workers on AWS. Comma-separated list;
# clips route least-busy across workers with failover.
# LOCAL: reach them through SSM tunnels — start with scripts/wan-tunnels.sh:
COMFY_URL=http://localhost:9010,http://localhost:9011,http://localhost:9013
# VERCEL/remote: the workers' :8188 is public, so point straight at the
# instance IPs, e.g. http://<ip-a>:8188,http://<ip-b>:8188,http://<ip-c>:8188
# (public IPv4 changes on stop/start unless the boxes have Elastic IPs).
# Wan generation knobs (see lib/wan.ts): 33 frames @16fps (17 diffused then
# RIFE ×2) → ~2s clips.
WAN_LENGTH=33
WAN_GEN_LENGTH=17
WAN_WIDTH=480
WAN_HEIGHT=864
# WAN_FPS=16
# WAN_STEPS=4         # 4-step Lightning
# WAN_BOUNDARY=2      # high→low expert switch step

# Background-music library: each session randomly gets one .mp3 from
# public/music (three ~9-min chunks of one long track), started when time
# travel begins and played continuously through the film.
# MUSIC_DIR=public/music
