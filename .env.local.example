# Gemini API key (used for both research grounding + Nano Banana 2 image generation)
GEMINI_API_KEY=

# SerpAPI key (Google Images reference photos)
SERPAPI_KEY=

# Optional overrides
GEMINI_RESEARCH_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
# Voiceover: ~60s packed-summer-day narration that reads the film's
# storyboard in slide order (one sentence per scene).
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# GEMINI_TTS_VOICE=Charon

# The film defaults to a live-only Ken Burns slideshow of ~10 stills (3
# era-only warm slides + 7 researched moments) that loops forever, paced so
# one pass spans the voiceover narrating over ducked background music. No
# file is rendered or shared.
# Set to 1 to switch back to Wan 2.2 motion clips (that path stitches an mp4).
# NEXT_PUBLIC_USE_WAN=1

# Video: self-hosted Wan 2.2 I2V A14B (MoE) + 4-step Lightning, kept warm on
# L40S boxes via ComfyUI, each reached through its own SSM tunnel.
# Comma-separated list; clips round-robin across workers with failover.
# Start the tunnels on the Mac if they aren't up: scripts/wan-tunnels.sh
COMFY_URL=http://localhost:9010,http://localhost:9011
# Wan generation knobs (see lib/wan.ts). Current setup: 320x576, 5 clips × 2s
# (33 frames @16fps, 17 diffused then RIFE ×2) for a 10s film.
WAN_LENGTH=33
WAN_GEN_LENGTH=17
# WAN_WIDTH=320
# WAN_HEIGHT=576
# WAN_FPS=16
# WAN_STEPS=4         # 4-step Lightning
# WAN_BOUNDARY=2      # high→low expert switch step

# Background-music library: each session randomly gets one .mp3 from this dir
# (three ~9-min chunks of one long track), started when time travel begins
# and played continuously through the film (ducked while the voiceover
# speaks).
# MUSIC_DIR=assets/music
