# Gemini API key (used for research grounding + Nano Banana 2 image generation)
GEMINI_API_KEY=

# Real reference photos for grounding stills (lib/refimages.ts).
# Provider chain, first working provider wins. Keyed providers lead (real
# Google Images, reliable on Vercel); keyless scrapers trail. Candidates are
# vision-vetted (filterRelevantRefs) before they can ground a scene.
#   1. Serper.dev — real Google Images, ~$0.001/search, 2,500 free credits.
#      Get a key at https://serper.dev (no card for the free tier). PRIMARY.
SERPER_API_KEY=
#   2. Google Programmable Search — CLOSED to new customers, sunsets
#      2027-01-01. Legacy only; leave unset unless you already have a key.
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_CX=
#   3. SerpAPI — paid Google Images, only used if set.
# SERPAPI_KEY=
#   4. DuckDuckGo — keyless, free, works locally but IP-blocked on Vercel.
#      The default when no key above is set; needs no config.
#   5. Bing HTML scrape — keyless last resort (unreliable; vision filter vets).

# Optional model overrides
GEMINI_RESEARCH_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image

# The film: 7 scenes × 2s (3 era-only warm slides + 4 researched moments).
# Each scene shows its Nano Banana still (Ken Burns) and upgrades in place to
# a Wan 2.2 motion clip. The shareable mp4 uses the first ~14s of the music.
# Set to 1 to switch to the legacy pure-clip path.
# NEXT_PUBLIC_USE_WAN=1

# Video: self-hosted Wan 2.2 I2V A14B (MoE) + 4-step Lightning, kept warm on
# 3× g6e.2xlarge (NVIDIA L40S) ComfyUI workers on AWS. Comma-separated list;
# clips route least-busy across workers with failover.
# LOCAL: reach them through SSM tunnels — start with scripts/wan-tunnels.sh:
COMFY_URL=http://localhost:9010,http://localhost:9011,http://localhost:9013
# VERCEL/remote: leave COMFY_URL unset. Workers are discovered live from EC2
# by the Fleet=wan tag (lib/fleet.ts) and reached through each box's
# token-auth proxy on :8443 — public IPs change on every stop/start, so
# nothing is pinned. The fleet is on-demand: /api/warm boots stopped boxes
# when a user enters, and each box stops itself after 15 idle minutes.
# FLEET_AWS_ACCESS_KEY_ID=      # IAM user "relive-fleet": DescribeInstances +
# FLEET_AWS_SECRET_ACCESS_KEY=  # StartInstances on the wan boxes only
# FLEET_AWS_REGION=us-east-1
# WAN_TOKEN=                    # shared secret the :8443 proxies require
# Wan generation knobs (see lib/wan.ts): 33 frames @16fps (17 diffused then
# RIFE ×2) → ~2s clips.
WAN_LENGTH=33
WAN_GEN_LENGTH=17
WAN_WIDTH=480
WAN_HEIGHT=864
# WAN_FPS=16
# WAN_STEPS=4         # 4-step Lightning
# WAN_BOUNDARY=2      # high→low expert switch step

# Background-music library: each session randomly gets one .mp3 from
# public/music (three ~9-min chunks of one long track), started when time
# travel begins and played continuously through the film.
# MUSIC_DIR=public/music
